      "@cosmox/http-auth": "file:../cosmox-shared-services/packages/http-auth",
      "@cosmox/internal-client": "file:../cosmox-shared-services/packages/internal-client",
      "@cosmox/providers": "file:../cosmox-shared-services/packages/providers",
